# Copy to .env and fill in.  Used by docker-compose.yml.

# --- Domain / TLS ---------------------------------------------------------- #
# Hostname the demo is served on.
WEBATM_DOMAIN=webatm.amvlab.eu
# Cert is requested as a wildcard via Cloudflare DNS-01.
CERT_DOMAIN=amvlab.eu
CERT_WILDCARD=*.amvlab.eu
# Let's Encrypt account e-mail (kept out of traefik.yml).
ACME_EMAIL=admin@amvlab.eu

# --- Cloudflare DNS-01 challenge ------------------------------------------- #
CF_API_EMAIL=you@example.com
# Scoped token with Zone:DNS:Edit on the zone above.
CF_DNS_API_TOKEN=replace-me

# --- Misc ------------------------------------------------------------------ #
TZ=Europe/Amsterdam

# --- Controller tuning (optional) ------------------------------------------ #
# How often to poll replica /status (seconds).
POLL_INTERVAL=5
# Recycle an IDLE replica once it has been up this long (seconds). 3600 = 1h.
RECYCLE_INTERVAL=3600
# Set to 0 to disable the hourly idle recycle entirely.
RECYCLE_ENABLED=1
# Optional CSV session log inside the controller container (mounted to ./controller/log).
# Leave empty to disable. Example: /log/webatm-sessions.csv
CSV_FILE=
