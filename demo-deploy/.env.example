# Copy to .env and fill in.  Used by docker-compose.yml.

# --- Domain / TLS ---------------------------------------------------------- #
# Hostname the demo is served on.
WEBATM_DOMAIN=webatm.amvlab.eu
# Cert is requested as a wildcard via Cloudflare DNS-01.
CERT_DOMAIN=amvlab.eu
CERT_WILDCARD=*.amvlab.eu
# Let's Encrypt account e-mail (kept out of traefik.yml).
ACME_EMAIL=admin@amvlab.eu

# --- Cloudflare DNS-01 challenge ------------------------------------------- #
CF_API_EMAIL=you@example.com
# Scoped token with Zone:DNS:Edit on the zone above.
CF_DNS_API_TOKEN=replace-me

# --- Misc ------------------------------------------------------------------ #
TZ=Europe/Amsterdam

# --- Image / sandbox runtime ----------------------------------------------- #
# The webatm image. Pinned to a released version for reproducibility (the
# public ghcr image ships offline tiles/glyphs/navdata baked in). Bump this to
# upgrade; point it at a local tag (e.g. webatm-integrated:local) only if you
# build yourself -- note a local build lacks the hydrated static assets.
WEBATM_IMAGE=ghcr.io/amvlab/webatm-integrated:0.4.2
# Sandbox runtime for the webatm replicas. `runsc` = gVisor (REQUIRED for a
# safe anonymous public demo; install gVisor on the host first). Use `runc`
# only for local testing without gVisor -- that is NOT a sandbox.
WEBATM_RUNTIME=runsc
# Max writable storage per visitor (BlueSky workdir = uploads + sim output).
# RAM-backed tmpfs, capped; counts toward the container memory limit.
BLUESKY_TMPFS_SIZE=256m

# --- Controller tuning (optional) ------------------------------------------ #
# How often to poll replica /status (seconds).
POLL_INTERVAL=5
# Master switch for recycling.
RECYCLE_ENABLED=1
# Wipe a replica this many seconds after its visitor leaves (disposable sandbox).
RECYCLE_IDLE_GRACE=120
# Hard cap on a single continuous session in seconds (kicks a camper). 0 = none.
MAX_SESSION_TIME=1200
# Session-history CSV. On by default; written to the named `webatm-logs`
# Docker volume so it survives `docker compose down`. Set empty to disable.
CSV_FILE=/log/webatm-sessions.csv
# Seconds between CSV rows (decoupled from the faster poll cadence).
CSV_INTERVAL=60
# Retention cap: keep at most this many rows (oldest trimmed). 0 = unlimited.
CSV_MAX_ROWS=100000
