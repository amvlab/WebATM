{
    "version": 8,
    "name": "WebATM Offline Dark",
    "glyphs": "/static/glyphs/{fontstack}/{range}.pbf",
    "metadata": {
        "description": "Minimal Protomaps-schema dark basemap for WebATM offline mode. Rendered directly from a local .pmtiles archive served by Flask. The basemap itself has no labels; glyphs are referenced only so WebATM's overlay labels (airports/waypoints, shapes, aircraft) can render offline - see WebATM/static/glyphs/README.md to populate them."
    },
    "sources": {
        "protomaps": {
            "type": "vector",
            "url": "pmtiles:///static/tiles/world.pmtiles",
            "attribution": "<a href=\"https://protomaps.com\">Protomaps</a> © <a href=\"https://openstreetmap.org\">OpenStreetMap</a>"
        },
        "terrain-dem": {
            "type": "raster-dem",
            "url": "https://tiles.mapterhorn.com/tilejson.json",
            "attribution": "<a href=\"https://mapterhorn.com/attribution/\" target=\"_blank\" rel=\"noopener\">© Mapterhorn</a>"
        }
    },
    "layers": [
        {
            "id": "background",
            "type": "background",
            "paint": { "background-color": "#0b0f15" }
        },
        {
            "id": "earth",
            "type": "fill",
            "source": "protomaps",
            "source-layer": "earth",
            "paint": { "fill-color": "#141a22" }
        },
        {
            "id": "landuse",
            "type": "fill",
            "source": "protomaps",
            "source-layer": "landuse",
            "filter": ["in", ["get", "kind"], ["literal", ["urban_area", "residential", "industrial"]]],
            "paint": { "fill-color": "#1a2029", "fill-opacity": 0.7 }
        },
        {
            "id": "natural",
            "type": "fill",
            "source": "protomaps",
            "source-layer": "natural",
            "filter": ["in", ["get", "kind"], ["literal", ["forest", "wood", "park", "grass", "nature_reserve"]]],
            "paint": { "fill-color": "#12201a" }
        },
        {
            "id": "water",
            "type": "fill",
            "source": "protomaps",
            "source-layer": "water",
            "paint": { "fill-color": "#05131f" }
        },
        {
            "id": "hillshade",
            "type": "hillshade",
            "source": "terrain-dem",
            "layout": { "visibility": "none" },
            "paint": {
                "hillshade-shadow-color": "#000000",
                "hillshade-highlight-color": "#1a2029",
                "hillshade-accent-color": "#0b0f15",
                "hillshade-exaggeration": 0.4
            }
        },
        {
            "id": "physical_line-river",
            "type": "line",
            "source": "protomaps",
            "source-layer": "physical_line",
            "filter": ["==", ["get", "kind"], "river"],
            "paint": { "line-color": "#05131f", "line-width": ["interpolate", ["linear"], ["zoom"], 6, 0.3, 14, 2] }
        },
        {
            "id": "roads-minor",
            "type": "line",
            "source": "protomaps",
            "source-layer": "roads",
            "minzoom": 10,
            "filter": ["in", ["get", "kind"], ["literal", ["minor_road", "other"]]],
            "paint": { "line-color": "#2b333d", "line-width": ["interpolate", ["linear"], ["zoom"], 10, 0.3, 16, 1.5] }
        },
        {
            "id": "roads-major",
            "type": "line",
            "source": "protomaps",
            "source-layer": "roads",
            "minzoom": 10,
            "filter": ["in", ["get", "kind"], ["literal", ["medium_road", "major_road"]]],
            "paint": { "line-color": "#3a4450", "line-width": ["interpolate", ["linear"], ["zoom"], 10, 0.6, 16, 2.5] }
        },
        {
            "id": "roads-highway",
            "type": "line",
            "source": "protomaps",
            "source-layer": "roads",
            "minzoom": 10,
            "filter": ["==", ["get", "kind"], "highway"],
            "paint": { "line-color": "#4a5566", "line-width": ["interpolate", ["linear"], ["zoom"], 10, 0.8, 16, 3.5] }
        },
        {
            "id": "coastline",
            "type": "line",
            "source": "protomaps",
            "source-layer": "earth",
            "paint": {
                "line-color": "#6b7788",
                "line-width": ["interpolate", ["linear"], ["zoom"], 0, 0.3, 6, 1]
            }
        },
        {
            "id": "boundaries-country",
            "type": "line",
            "source": "protomaps",
            "source-layer": "boundaries",
            "filter": ["<=", ["get", "kind_detail"], 2],
            "paint": {
                "line-color": "#6b7788",
                "line-width": ["interpolate", ["linear"], ["zoom"], 0, 0.3, 6, 1],
                "line-dasharray": [3, 2]
            }
        },
        {
            "id": "boundaries-region",
            "type": "line",
            "source": "protomaps",
            "source-layer": "boundaries",
            "minzoom": 4,
            "filter": ["==", ["get", "kind_detail"], 4],
            "paint": {
                "line-color": "#4a5566",
                "line-width": ["interpolate", ["linear"], ["zoom"], 4, 0.2, 10, 0.7],
                "line-dasharray": [2, 2]
            }
        }
    ]
}
